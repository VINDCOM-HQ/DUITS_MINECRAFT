{
  "name": "duits-mc-rcon-client",
  "version": "2.0.0",
  "description": "DUITS DUITS Minecraft RMM Tool",
  "main": "main.js",
  "author": "Harrison Windberg",
  "license": "MIT",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./input.css -o ./tailwind.css --minify",
    "start": "npm run build:css && electron .",
    "dist": "npm run build:css && electron-builder"
  },
  "devDependencies": {
    "@parcel/watcher": "^2.5.1",
    "@tailwindcss/cli": "^4.1.4",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "electron-wix-msi": "^5.1.3",
    "tailwindcss": "^4.1.4"
  },
  "build": {
    "appId": "com.duits.mcrcon",
    "productName": "DUITS DUITS Minecraft RMM Tool",
    "files": [
      "index.html",
      "preload.js",
      "preload/",
      "main.js",
      "tailwind.css",
      "ipc/**/*",
      "lib/**/*",
      "agent/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "asar": true,
    "win": {
      "target": "msi",
      "executableName": "DUITS DUITS Minecraft RMM Tool",
      "icon": "icon.ico"
    },
    "msi": {
      "perMachine": true,
      "shortcutName": "DUITS DUITS Minecraft RMM Tool"
    }
  },
  "dependencies": {
    "axios": "^1.8.4",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.14.0",
    "rcedit": "^4.0.1",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.8.1",
    "tail": "^2.2.6",
    "uuid": "^11.1.0",
    "ws": "^8.18.1"
  }
}
