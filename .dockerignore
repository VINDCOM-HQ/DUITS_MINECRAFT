# Git
.git
.gitignore

# Node dependencies (re-installed during build)
node_modules
**/node_modules

# Web build artefacts (rebuilt during image build)
web/.svelte-kit
web/build

# Gradle caches and intermediate build outputs — keep only the final jars
NetherDeck Server/.gradle
NetherDeck Server/build/classes
NetherDeck Server/build/generated
NetherDeck Server/build/reports
NetherDeck Server/build/resources
NetherDeck Server/build/tmp
NetherDeck Server/**/build/classes
NetherDeck Server/**/build/generated
NetherDeck Server/**/build/reports
NetherDeck Server/**/build/resources
NetherDeck Server/**/build/tmp
NetherDeck Server/**/build/libs
# Re-include the root libs (the final collected jars)
!NetherDeck Server/build/libs

# Desktop app (Electron — not part of the container)
desktop

# Logs
logs

# Dev secrets
agent/.env
web/.env

# IDE / OS
.vscode
.claude
*.pfx
*.crt
*.key
code_sign.*
