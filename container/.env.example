# ==============================================
# Infrastructure Configuration
# ==============================================
MYSQL_USER=mcuser
MYSQL_PASSWORD=PW_HERE
SMB_USER=mcadmin
SMB_PASSWORD=PW_HERE
DATABASE_NAME=minecraft
TZ=UTC

# MySQL bind address (default: 127.0.0.1 for local only)
# Set to 0.0.0.0 if you need external MySQL access via port 3306
# MC_MYSQL_BIND=127.0.0.1

# ==============================================
# Java Memory Configuration
# ==============================================
# Passed directly to -Xms (min heap) and -Xmx (max heap)
# MC_MIN_MEMORY=2G
# MC_MAX_MEMORY=6G

# ==============================================
# Minecraft Server Configuration (server.properties)
# All MC_* variables are optional - only set what you need
# ==============================================

# --- EULA Acceptance ---
# Set to "true" to accept the Minecraft EULA
# MC_EULA=true

# --- Server Basics ---
# MC_MOTD=A Minecraft Server
# MC_SERVER_PORT=25565
# MC_SERVER_IP=
# MC_MAX_PLAYERS=20
# MC_LEVEL_NAME=world
# MC_LEVEL_SEED=
# MC_LEVEL_TYPE=minecraft:normal
# MC_GENERATOR_SETTINGS={}

# --- Gameplay Settings ---
# MC_GAMEMODE=survival
# MC_FORCE_GAMEMODE=false
# MC_DIFFICULTY=easy
# MC_HARDCORE=false
# MC_PVP=true
# MC_ALLOW_FLIGHT=false
# MC_ALLOW_NETHER=true

# --- Spawn Settings ---
# MC_SPAWN_PROTECTION=16
# MC_SPAWN_NPCS=true
# MC_SPAWN_ANIMALS=true
# MC_SPAWN_MONSTERS=true

# --- World Settings ---
# MC_VIEW_DISTANCE=10
# MC_SIMULATION_DISTANCE=10
# MC_MAX_WORLD_SIZE=29999984
# MC_MAX_BUILD_HEIGHT=256
# MC_GENERATE_STRUCTURES=true

# --- Security and Access ---
# MC_ONLINE_MODE=true
# MC_WHITE_LIST=false
# MC_ENFORCE_WHITELIST=false
# MC_ENFORCE_SECURE_PROFILE=true
# MC_ENABLE_COMMAND_BLOCK=false
# MC_OP_PERMISSION_LEVEL=4
# MC_FUNCTION_PERMISSION_LEVEL=2

# --- RCON Configuration ---
# MC_ENABLE_RCON=false
# MC_RCON_PORT=25575
# MC_RCON_PASSWORD=
# MC_BROADCAST_RCON_TO_OPS=true

# --- Query Configuration ---
# MC_ENABLE_QUERY=false
# MC_QUERY_PORT=25565

# --- Performance Settings ---
# MC_MAX_TICK_TIME=60000
# MC_NETWORK_COMPRESSION_THRESHOLD=256
# MC_RATE_LIMIT=0
# MC_PLAYER_IDLE_TIMEOUT=0
# MC_ENTITY_BROADCAST_RANGE=100
# MC_MAX_CHAINED_NEIGHBOR_UPDATES=1000000

# --- Server Behavior ---
# MC_PREVENT_PROXY_CONNECTIONS=false
# MC_USE_NATIVE_TRANSPORT=true
# MC_SYNC_CHUNK_WRITES=true
# MC_ENABLE_JMX_MONITORING=false
# MC_BROADCAST_CONSOLE_TO_OPS=true
# MC_ENABLE_STATUS=true
# MC_HIDE_ONLINE_PLAYERS=false
# MC_PAUSE_WHEN_EMPTY_SECONDS=-1

# --- Resource Pack ---
# MC_RESOURCE_PACK=
# MC_RESOURCE_PACK_SHA1=
# MC_RESOURCE_PACK_ID=
# MC_REQUIRE_RESOURCE_PACK=false
# MC_RESOURCE_PACK_PROMPT=

# --- Data Packs ---
# MC_INITIAL_ENABLED_PACKS=vanilla
# MC_INITIAL_DISABLED_PACKS=

# --- Advanced Settings ---
# MC_ACCEPTS_TRANSFERS=false
# MC_LOG_IPS=true
# MC_DEBUG=false
# MC_BUG_REPORT_LINK=
# MC_REGION_FILE_COMPRESSION=deflate
# MC_TEXT_FILTERING_CONFIG=
# MC_TEXT_FILTERING_VERSION=0

# ==============================================
# Agent Relay Configuration
# ==============================================
# Enable the agent relay server (allows remote management via Minecraft RCON app)
# ENABLE_AGENT=false

# Port for the agent relay server
# AGENT_PORT=3500

# API key for authenticating with the agent (auto-generated if not set)
# AGENT_API_KEY=

# ==============================================
# Web Portal Configuration
# ==============================================
# Enable the web management portal (automatically enables agent relay)
# ENABLE_WEB_PORTAL=false

# Port for the web portal
# WEB_PORTAL_PORT=3000

# Session secret for cookie signing (auto-generated if not set)
# WEB_PORTAL_SESSION_SECRET=
