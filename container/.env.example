# ==============================================
# Infrastructure Configuration
# ==============================================
MYSQL_USER=mcuser
MYSQL_PASSWORD=PW_HERE
SMB_USER=mcadmin
SMB_PASSWORD=PW_HERE
DATABASE_NAME=minecraft
TZ=UTC

# MySQL bind address (default: 127.0.0.1 for local only)
# Set to 0.0.0.0 if you need external MySQL access via port 3306
# MC_MYSQL_BIND=127.0.0.1

# ==============================================
# Java Memory Configuration
# ==============================================
# Passed directly to -Xms (min heap) and -Xmx (max heap)
# MC_MIN_MEMORY=2G
# MC_MAX_MEMORY=6G

# ==============================================
# Minecraft Server Configuration (server.properties)
# All MC_* variables are optional - only set what you need
# ==============================================

# --- EULA Acceptance ---
# Set to "true" to accept the Minecraft EULA
# MC_EULA=true

# --- Server Basics ---
# MC_MOTD=A Minecraft Server
# MC_SERVER_PORT=25565
# MC_SERVER_IP=
# MC_MAX_PLAYERS=20
# MC_LEVEL_NAME=world
# MC_LEVEL_SEED=
# MC_LEVEL_TYPE=minecraft:normal
# MC_GENERATOR_SETTINGS={}

# --- Gameplay Settings ---
# MC_GAMEMODE=survival
# MC_FORCE_GAMEMODE=false
# MC_DIFFICULTY=easy
# MC_HARDCORE=false
# MC_PVP=true
# MC_ALLOW_FLIGHT=false
# MC_ALLOW_NETHER=true

# --- Spawn Settings ---
# MC_SPAWN_PROTECTION=16
# MC_SPAWN_NPCS=true
# MC_SPAWN_ANIMALS=true
# MC_SPAWN_MONSTERS=true

# --- World Settings ---
# MC_VIEW_DISTANCE=10
# MC_SIMULATION_DISTANCE=10
# MC_MAX_WORLD_SIZE=29999984
# MC_MAX_BUILD_HEIGHT=256
# MC_GENERATE_STRUCTURES=true

# --- Security and Access ---
# MC_ONLINE_MODE=true
# MC_WHITE_LIST=false
# MC_ENFORCE_WHITELIST=false
# MC_ENFORCE_SECURE_PROFILE=true
# MC_ENABLE_COMMAND_BLOCK=false
# MC_OP_PERMISSION_LEVEL=4
# MC_FUNCTION_PERMISSION_LEVEL=2

# --- RCON Configuration ---
# MC_ENABLE_RCON=false
# MC_RCON_PORT=25575
# MC_RCON_PASSWORD=
# MC_BROADCAST_RCON_TO_OPS=true

# --- Query Configuration ---
# MC_ENABLE_QUERY=false
# MC_QUERY_PORT=25565

# --- Performance Settings ---
# MC_MAX_TICK_TIME=60000
# MC_NETWORK_COMPRESSION_THRESHOLD=256
# MC_RATE_LIMIT=0
# MC_PLAYER_IDLE_TIMEOUT=0
# MC_ENTITY_BROADCAST_RANGE=100
# MC_MAX_CHAINED_NEIGHBOR_UPDATES=1000000

# --- Server Behavior ---
# MC_PREVENT_PROXY_CONNECTIONS=false
# MC_USE_NATIVE_TRANSPORT=true
# MC_SYNC_CHUNK_WRITES=true
# MC_ENABLE_JMX_MONITORING=false
# MC_BROADCAST_CONSOLE_TO_OPS=true
# MC_ENABLE_STATUS=true
# MC_HIDE_ONLINE_PLAYERS=false
# MC_PAUSE_WHEN_EMPTY_SECONDS=-1

# --- Resource Pack ---
# MC_RESOURCE_PACK=
# MC_RESOURCE_PACK_SHA1=
# MC_RESOURCE_PACK_ID=
# MC_REQUIRE_RESOURCE_PACK=false
# MC_RESOURCE_PACK_PROMPT=

# --- Data Packs ---
# MC_INITIAL_ENABLED_PACKS=vanilla
# MC_INITIAL_DISABLED_PACKS=

# --- Advanced Settings ---
# MC_ACCEPTS_TRANSFERS=false
# MC_LOG_IPS=true
# MC_DEBUG=false
# MC_BUG_REPORT_LINK=
# MC_REGION_FILE_COMPRESSION=deflate
# MC_TEXT_FILTERING_CONFIG=
# MC_TEXT_FILTERING_VERSION=0

# ==============================================
# Agent Relay Configuration
# ==============================================
# Enable the agent relay server (allows remote management via Minecraft RCON app)
# ENABLE_AGENT=false

# Port for the agent relay server
# AGENT_PORT=3500

# API key for authenticating with the agent (auto-generated if not set)
# AGENT_API_KEY=

# ==============================================
# Web Portal Configuration
# ==============================================
# Enable the web management portal
# ENABLE_WEB_PORTAL=false

# Port for the web portal
# WEB_PORTAL_PORT=3000

# Session secret for cookie signing (auto-generated if not set)
# WEB_PORTAL_SESSION_SECRET=

# --- MySQL Connection ---
# Shared by portal and game databases. Defaults to built-in MySQL.
# Set WEB_PORTAL_DB_HOST to point to an external MySQL instance.
# WEB_PORTAL_DB_HOST=localhost
# WEB_PORTAL_DB_PORT=3306
# WEB_PORTAL_DB_USER=netherdeck
# WEB_PORTAL_DB_PASSWORD=                  # auto-generated if empty
# WEB_PORTAL_DB_NAME=netherdeck

# --- Break-Glass Admin ---
# Seeded into the portal DB on first run. REQUIRED for initial login.
# WEB_PORTAL_ADMIN_USER=admin
# WEB_PORTAL_ADMIN_PASSWORD=               # REQUIRED - set a strong password

# --- Portal RCON ---
# Direct RCON connection from the portal to Minecraft server
# WEB_PORTAL_RCON_HOST=localhost
# WEB_PORTAL_RCON_PORT=25575
# WEB_PORTAL_RCON_PASSWORD=                # reads MC_RCON_PASSWORD if not set

# --- Game Database Name ---
# The portal and game data share the same MySQL instance (configured above).
# Only the database name differs. Defaults to MYSQL_DATABASE if not set.
# WEB_PORTAL_GAME_DB_NAME=                 # defaults to MYSQL_DATABASE (e.g. minecraft)

# --- Minecraft Files ---
# WEB_PORTAL_MC_DIR=/minecraft

# --- OAuth / OIDC (optional) ---
# Generic OpenID Connect support (works with Google, Keycloak, Auth0, etc.)
# WEB_PORTAL_OAUTH_ENABLED=false
# WEB_PORTAL_OAUTH_ISSUER_URL=             # e.g. https://accounts.google.com
# WEB_PORTAL_OAUTH_CLIENT_ID=
# WEB_PORTAL_OAUTH_CLIENT_SECRET=
# WEB_PORTAL_OAUTH_SCOPES=openid profile email
# WEB_PORTAL_OAUTH_CALLBACK_URL=           # e.g. https://mc.example.com/auth/oauth/callback

# --- SAML 2.0 (optional) ---
# Enterprise SSO via SAML 2.0 (works with Okta, Azure AD, ADFS, etc.)
# WEB_PORTAL_SAML_ENABLED=false
# WEB_PORTAL_SAML_IDP_METADATA_URL=        # e.g. https://idp.example.com/metadata
# WEB_PORTAL_SAML_ENTITY_ID=               # e.g. https://mc.example.com
# WEB_PORTAL_SAML_CALLBACK_URL=            # e.g. https://mc.example.com/auth/saml/callback
