# DUITS Minecraft RMM Agent Configuration
# Copy this file to .env and modify as needed

# Required settings
# Generate a strong random API key (use a password generator)
AGENT_API_KEY=your-api-key-here
AGENT_PORT=3500

# TLS/HTTPS settings (optional)
# Set to 1 or true to enable HTTPS
AGENT_ENABLE_TLS=false
# Paths to TLS certificate and key files
AGENT_TLS_CERT=/path/to/cert.pem
AGENT_TLS_KEY=/path/to/key.pem
AGENT_TLS_PASSPHRASE=

# Other settings
# Log format: combined, common, dev, short, or tiny
AGENT_LOG_FORMAT=combined
# Set to 1 or true to enable CORS for all origins
AGENT_ALLOW_CORS=true