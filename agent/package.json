{
  "name": "vindcom-netherdeck-agent",
  "version": "1.0.0",
  "description": "Relay/Proxy agent for VINDCOM NetherDeck",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "jest",
    "service:install": "node ./scripts/install-service.js",
    "service:uninstall": "node ./scripts/uninstall-service.js",
    "init": "cp .env.example .env && echo 'Created .env file. Please edit it with your configuration.'",
    "setup": "node ./scripts/setup.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.18.2",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0",
    "ws": "^8.18.1"
  },
  "optionalDependencies": {
    "node-windows": "^1.0.0-beta.8"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
